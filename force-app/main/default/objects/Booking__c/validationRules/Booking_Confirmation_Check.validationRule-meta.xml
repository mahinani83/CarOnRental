<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Booking_Confirmation_Check</fullName>
    <active>true</active>
    <errorConditionFormula>ISPICKVAL(  Status__c  , &quot;Confirmed&quot;) &amp;&amp;ISPICKVAL(   Payment_Status__c , &quot;Pending&quot;)</errorConditionFormula>
    <errorMessage>Can not Confirm  Booking With Pending Payment Status</errorMessage>
</ValidationRule>
