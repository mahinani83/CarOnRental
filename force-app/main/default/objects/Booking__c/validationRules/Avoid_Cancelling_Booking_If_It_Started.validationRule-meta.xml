<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Avoid_Cancelling_Booking_If_It_Started</fullName>
    <active>true</active>
    <errorConditionFormula>Start_Date_Time__c &gt; now() &amp;&amp;  ISPICKVAL( Status__c , &quot;Cancelled&quot;)</errorConditionFormula>
    <errorMessage>Can Not Cancel Booking if It Is Already Started</errorMessage>
</ValidationRule>
